################################################################################
# Judge0 CE — staging / production (internet-facing VM)
# Copy to judge0.conf and replace CHANGE_ME_* values:
#   openssl rand -hex 24
# Never commit judge0.conf with real secrets.
################################################################################

JUDGE0_TELEMETRY_ENABLE=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=judge0
POSTGRES_USER=judge0
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Required on public VMs — Railway sends this as JUDGE0_API_KEY
AUTHN_HEADER=X-Auth-Token
AUTHN_TOKEN=CHANGE_ME_AUTHN_TOKEN
