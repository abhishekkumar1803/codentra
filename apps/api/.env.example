# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL="postgresql://codentra:codentra@localhost:5432/codentra?schema=public"

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Razorpay (optional for local dev — set RAZORPAY_MOCK=true to skip)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=plan_membership_monthly
RAZORPAY_MOCK=true
MEMBERSHIP_AMOUNT_PAISE=4900

# Resend (optional — set RESEND_MOCK=true to log emails in dev)
RESEND_MOCK=true
RESEND_API_KEY=
RESEND_FROM=Codentra <noreply@codentra.dev>
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
